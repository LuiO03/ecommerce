APP_NAME=GECKOMERCE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Ejemplo para SMTP real
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.tu-dominio.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_usuario
# MAIL_PASSWORD=tu_password
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ==============================
# PASARELAS DE PAGO (CHECKOUT)
# ==============================

# Niubiz (VisaNet)
NIUBIZ_MERCHANT_ID=
NIUBIZ_USER=
NIUBIZ_PASSWORD=
NIUBIZ_URL_API=
NIUBIZ_URL_JS=
NIUBIZ_COUNTABLE=true
NIUBIZ_WEBHOOK_SECRET=
NIUBIZ_DEV_SIMULATION=false

# Culqi
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=
CULQI_BASE_URL=https://api.culqi.com
CULQI_CHECKOUT_URL=https://checkout.culqi.com/js/v4
CULQI_WEBHOOK_SECRET=
CULQI_DEV_SIMULATION=false

# Mercado Pago
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_SECRET_KEY=
MERCADO_PAGO_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_CHECKOUT_URL=https://sdk.mercadopago.com/js/v2
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_DEV_SIMULATION=false
